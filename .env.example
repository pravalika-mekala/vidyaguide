# APP CONFIG
APP_ENV=development
APP_NAME=Vidyaguide
SESSION_SECRET=your_very_long_random_session_secret_min_16_chars
SESSION_HTTPS_ONLY=False
SESSION_SAME_SITE=lax
SESSION_MAX_AGE_SECONDS=28800

# DATABASE CONFIG (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=vidyaguide
DB_POOL_NAME=vidyaguide_pool
DB_POOL_SIZE=5

# AI CONFIG (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# MAIL CONFIG (SMTP for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_no_spaces
SMTP_SENDER=your_email@gmail.com

# OTP CONFIG
OTP_CONSOLE_FALLBACK=False
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_EMAIL_WINDOW=3
OTP_MAX_REQUESTS_PER_IP_WINDOW=20
OTP_RATE_WINDOW_SECONDS=900
OTP_HASH_PEPPER=your_random_pepper_min_12_chars

# LIMITS
MAX_UPLOAD_BYTES=5242880
MAX_CHAT_MESSAGE_CHARS=2000
AUTH_RATE_LIMIT_COUNT=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
CHAT_RATE_LIMIT_COUNT=30
CHAT_RATE_LIMIT_WINDOW_SECONDS=300
UPLOAD_RATE_LIMIT_COUNT=10
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=600

# SYSTEM
ENABLE_STARTUP_SCHEMA_SYNC=True
ADMIN_EMAILS=your_admin_email@example.com,another_admin@example.com
